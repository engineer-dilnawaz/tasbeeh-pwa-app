# Copy to `.env.local` and fill in (Vite loads `.env.local` automatically).

# Shown in the app and should match Firebase Console → Project settings → Public-facing name (auth emails).
VITE_PUBLIC_APP_NAME=Tasbeeh

# Privacy Policy & data-deletion pages (mailto). Required for production legal/Facebook review.
# VITE_SUPPORT_EMAIL=you@yourdomain.com

# Optional: if the deployed origin differs from window.location.origin (email link redirect URL).
# VITE_APP_ORIGIN=https://your-domain.com

# Firebase
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# IslamicAPI (https://islamicapi.com/) — Asma-ul-Husna etc. Key as query param `api_key`.
VITE_ISLAMIC_API_KEY=

# Sentry (https://sentry.io) — browser crash reporting. Project DSN is safe to ship in the client bundle.
# VITE_SENTRY_DSN=https://____@____.ingest.sentry.io/____
# Optional: send events while running `yarn dev` (default: production builds only).
# VITE_SENTRY_ENABLE_IN_DEV=true
# Optional: environment name in Sentry (default: import.meta.env.MODE).
# VITE_SENTRY_ENVIRONMENT=production
# Optional: release string (default: tasbeeh-flow@<version> from package.json).
# VITE_SENTRY_RELEASE=tasbeeh-flow@git-sha
# Optional: default true; set to "false" to disable automatic PII in the Sentry SDK.
# VITE_SENTRY_SEND_DEFAULT_PII=false

# Optional: custom backend for tasbeeh catalog (see `api/islamicApi/tasbeehRemote.ts`)
VITE_ISLAMIC_API_BASE_URL=
