rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper to check if the document belongs to the authenticated user
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // 👤 Users collection
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // 📝 Tasbeeh Entries (Logs)
    match /tasbeeh-entries/{entryId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // 🔹 Public Tasbeehs (Custom shared tasbeehs)
    match /tasbeehs/{tasbeehId} {
      // Anyone can read (publicly visible tasbeehs)
      allow read: if true;

      // Only authenticated users can create new tasbeeh
      allow create: if isAuthenticated();

      // Only the creator can update or delete
      allow update, delete: if isAuthenticated() 
                            && request.resource.data.createdBy == request.auth.uid
                            && resource.data.createdBy == request.auth.uid;
    }
  }
}
